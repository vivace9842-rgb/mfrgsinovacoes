<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MFRGS Sentinela V3 — Painel de Leads</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --sage: #7a9e7e;
    --sage-light: #a8c5ac;
    --sage-dark: #4a7050;
    --gold: #c9a84c;
    --gold-light: #e8c97a;
    --gold-dark: #9a7830;
    --cream: #faf7f0;
    --dark: #1a1f1a;
    --panel: #232820;
    --card: #2a2f28;
    --border: rgba(255,255,255,0.07);
    --text: #e8ede8;
    --muted: rgba(232,237,232,0.45);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
  }

  .layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: 100vh;
  }

  /* SIDEBAR */
  .sidebar {
    background: var(--panel);
    border-right: 1px solid var(--border);
    padding: 32px 0;
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .sidebar-logo {
    padding: 0 24px 32px;
    border-bottom: 1px solid var(--border);
  }
  .sidebar-logo h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: var(--sage-light);
  }
  .sidebar-logo h2 span { color: var(--gold); }
  .sidebar-logo p {
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 4px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .sidebar-nav { padding: 24px 16px; flex: 1; }
  .nav-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 8px;
    margin-bottom: 8px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    font-size: 0.88rem;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.15s;
    margin-bottom: 2px;
  }
  .nav-item:hover, .nav-item.active {
    background: rgba(122,158,126,0.12);
    color: var(--sage-light);
  }
  .nav-item.active { font-weight: 500; }

  .sidebar-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--muted);
  }

  /* MAIN */
  .main { display: flex; flex-direction: column; overflow: hidden; }

  /* TOPBAR */
  .topbar {
    padding: 20px 32px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(26,31,26,0.8);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .topbar-left h1 { font-size: 1.1rem; font-weight: 600; color: var(--text); }
  .topbar-left p { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    border: none;
    transition: all 0.15s;
  }
  .btn-gold {
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
    color: var(--dark);
  }
  .btn-gold:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(201,168,76,0.3); }
  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-outline:hover { background: rgba(255,255,255,0.06); }
  .btn-sage {
    background: rgba(122,158,126,0.15);
    color: var(--sage-light);
    border: 1px solid rgba(122,158,126,0.2);
  }
  .btn-sage:hover { background: rgba(122,158,126,0.25); }
  .btn-whatsapp {
    background: rgba(37,211,102,0.12);
    color: #25d366;
    border: 1px solid rgba(37,211,102,0.2);
    padding: 6px 14px;
    font-size: 0.8rem;
  }
  .btn-whatsapp:hover { background: rgba(37,211,102,0.2); }
  .btn-danger {
    background: rgba(200,60,60,0.12);
    color: #e88080;
    border: 1px solid rgba(200,60,60,0.2);
    padding: 6px 14px;
    font-size: 0.8rem;
  }
  .btn-danger:hover { background: rgba(200,60,60,0.2); }

  /* CONTENT */
  .content { padding: 32px; overflow-y: auto; }

  /* METRICS */
  .metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 32px;
  }
  .metric-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: transform 0.15s;
  }
  .metric-card:hover { transform: translateY(-2px); }
  .metric-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }
  .metric-card.m-total::after  { background: var(--sage); }
  .metric-card.m-hoje::after   { background: var(--gold); }
  .metric-card.m-aguardo::after{ background: #7b9ec9; }
  .metric-card.m-saida::after  { background: #c97b7b; }

  .metric-label {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .metric-value {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1;
    color: var(--text);
  }
  .metric-sub { font-size: 0.75rem; color: var(--muted); margin-top: 6px; }

  /* FILTERS */
  .filters-bar {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .search-box { flex: 1; min-width: 200px; position: relative; }
  .search-box input {
    width: 100%;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 16px 10px 40px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .search-box input::placeholder { color: var(--muted); }
  .search-box input:focus { border-color: var(--sage); }
  .search-box::before {
    content: '🔍';
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.85rem;
    pointer-events: none;
  }
  .filter-select {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 16px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    outline: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .filter-select:focus { border-color: var(--sage); }
  option { background: #232820; }

  /* TABLE */
  .table-wrap {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .table-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .table-header h3 { font-size: 0.88rem; font-weight: 500; color: var(--muted); }
  .table-count {
    font-size: 0.78rem;
    color: var(--muted);
    background: rgba(255,255,255,0.05);
    padding: 4px 10px;
    border-radius: 100px;
  }

  table { width: 100%; border-collapse: collapse; }
  thead th {
    padding: 12px 16px;
    text-align: left;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    background: rgba(0,0,0,0.1);
    white-space: nowrap;
  }
  tbody tr {
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: rgba(255,255,255,0.03); }
  td { padding: 14px 16px; font-size: 0.88rem; vertical-align: middle; }

  .td-empresa strong { display: block; font-weight: 500; color: var(--text); margin-bottom: 2px; }
  .td-empresa span   { font-size: 0.75rem; color: var(--muted); }

  .td-phone { font-family: monospace; font-size: 0.82rem; color: var(--muted); }

  /* STATUS BADGE */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
  }
  .status-badge::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.8;
  }
  .status-entrada { background: rgba(122,158,126,0.15); color: #a8c5ac; }
  .status-aguardo { background: rgba(123,158,201,0.15); color: #9ec0e8; }
  .status-duvida  { background: rgba(201,168,76,0.15);  color: #e8c97a; }
  .status-saida   { background: rgba(201,123,123,0.15); color: #e8a0a0; }

  .status-select {
    background: transparent;
    border: none;
    outline: none;
    color: inherit;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    padding: 0;
    width: 100%;
  }

  .td-actions { display: flex; gap: 6px; align-items: center; }
  .td-date { font-size: 0.78rem; color: var(--muted); white-space: nowrap; }

  /* EMPTY */
  .empty-state { padding: 60px; text-align: center; color: var(--muted); }
  .empty-state .empty-icon { font-size: 2.5rem; margin-bottom: 12px; }
  .empty-state p { font-size: 0.9rem; margin-top: 8px; }

  /* LOADING */
  .loading-row td { text-align: center; padding: 48px; color: var(--muted); }

  /* MODAL */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    width: 100%;
    max-width: 460px;
    transform: translateY(20px) scale(0.97);
    transition: transform 0.2s;
  }
  .modal-overlay.open .modal { transform: translateY(0) scale(1); }
  .modal h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    margin-bottom: 24px;
    color: var(--text);
  }
  .modal-field { margin-bottom: 16px; }
  .modal-field label {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .modal-field input,
  .modal-field select {
    width: 100%;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.92rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .modal-field input:focus,
  .modal-field select:focus { border-color: var(--sage); }
  .modal-field select option { background: #232820; }
  .modal-actions { display: flex; gap: 10px; margin-top: 24px; }
  .modal-actions .btn { flex: 1; justify-content: center; }

  /* TOAST */
  .toast {
    position: fixed;
    bottom: 32px; right: 32px;
    padding: 14px 22px;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 500;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s;
    z-index: 9999;
    pointer-events: none;
    max-width: 320px;
  }
  .toast.show { opacity: 1; transform: translateY(0); }
  .toast.success { background: var(--sage-dark); color: #fff; border: 1px solid var(--sage); }
  .toast.error   { background: #7a3030; color: #fff; border: 1px solid #c05050; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }

  @media (max-width: 900px) {
    .layout { grid-template-columns: 1fr; }
    .sidebar { display: none; }
    .metrics { grid-template-columns: repeat(2, 1fr); }
    .content { padding: 20px; }
  }
</style>
</head>
<body>

<div class="layout">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <h2>MFRGS<span>.</span></h2>
      <p>Sentinela V3</p>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-label">Menu</div>
      <div class="nav-item active">📋 Leads</div>
      <div class="nav-item" onclick="showToast('Landing Page não configurada ainda.','error')">🌐 Landing Page</div>
    </nav>
    <div class="sidebar-footer">Gilberto · MFRGS Inovações</div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div class="topbar-left">
        <h1>Painel de Leads</h1>
        <p id="lastUpdate">Carregando...</p>
      </div>
      <div style="display:flex;gap:10px;">
        <button class="btn btn-outline" onclick="loadLeads()">↻ Atualizar</button>
        <button class="btn btn-gold" onclick="openModal()">+ Novo Lead</button>
      </div>
    </div>

    <div class="content">
      <div class="metrics">
        <div class="metric-card m-total">
          <div class="metric-label">Total de Leads</div>
          <div class="metric-value" id="metTotal">—</div>
          <div class="metric-sub">todos os registros</div>
        </div>
        <div class="metric-card m-hoje">
          <div class="metric-label">Hoje</div>
          <div class="metric-value" id="metHoje">—</div>
          <div class="metric-sub">novos hoje</div>
        </div>
        <div class="metric-card m-aguardo">
          <div class="metric-label">Em Aguardo</div>
          <div class="metric-value" id="metAguardo">—</div>
          <div class="metric-sub">aguardando retorno</div>
        </div>
        <div class="metric-card m-saida">
          <div class="metric-label">Saída</div>
          <div class="metric-value" id="metSaida">—</div>
          <div class="metric-sub">convertidos / encerrados</div>
        </div>
      </div>

      <div class="filters-bar">
        <div class="search-box">
          <input type="text" id="searchInput" placeholder="Buscar empresa ou contato..." oninput="applyFilters()">
        </div>
        <select class="filter-select" id="filterStatus" onchange="applyFilters()">
          <option value="">Todos os status</option>
          <option value="Entrada">Entrada</option>
          <option value="Aguardo">Aguardo</option>
          <option value="Dúvida">Dúvida</option>
          <option value="Saída">Saída</option>
        </select>
        <select class="filter-select" id="filterCidade" onchange="applyFilters()">
          <option value="">Todas as cidades</option>
        </select>
      </div>

      <div class="table-wrap">
        <div class="table-header">
          <h3>Lista de leads</h3>
          <span class="table-count" id="tableCount">0 registros</span>
        </div>
        <table>
          <thead>
            <tr>
              <th>Empresa / Contato</th>
              <th>Telefone</th>
              <th>Cidade</th>
              <th>Status</th>
              <th>Cadastro</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody id="leadsTableBody">
            <tr class="loading-row">
              <td colspan="6">⏳ Carregando leads...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<!-- MODAL: Novo Lead -->
<div class="modal-overlay" id="modalOverlay" onclick="handleOverlayClick(event)">
  <div class="modal">
    <h3 id="modalTitle">Novo Lead</h3>
    <div class="modal-field">
      <label>Empresa</label>
      <input type="text" id="fEmpresa" placeholder="Nome da empresa">
    </div>
    <div class="modal-field">
      <label>Contato</label>
      <input type="text" id="fContato" placeholder="Nome do responsável">
    </div>
    <div class="modal-field">
      <label>Telefone / WhatsApp</label>
      <input type="text" id="fTelefone" placeholder="(00) 00000-0000">
    </div>
    <div class="modal-field">
      <label>Cidade</label>
      <input type="text" id="fCidade" placeholder="Cidade">
    </div>
    <div class="modal-field">
      <label>Status</label>
      <select id="fStatus">
        <option value="Entrada">Entrada</option>
        <option value="Aguardo">Aguardo</option>
        <option value="Dúvida">Dúvida</option>
        <option value="Saída">Saída</option>
      </select>
    </div>
    <div class="modal-actions">
      <button class="btn btn-outline" onclick="closeModal()">Cancelar</button>
      <button class="btn btn-gold" onclick="saveLead()">💾 Salvar</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  // ─── LOCAL STORAGE KEY ───────────────────────────────────────────
  const STORAGE_KEY = 'mfrgs_leads_v3';

  // ─── STATE ───────────────────────────────────────────────────────
  let allLeads    = [];
  let filtered    = [];
  let editingId   = null;

  // ─── INIT ────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', loadLeads);

  // ─── LOAD ────────────────────────────────────────────────────────
  function loadLeads() {
    const raw = localStorage.getItem(STORAGE_KEY);
    allLeads  = raw ? JSON.parse(raw) : getDemoData();
    if (!raw) saveToStorage(); // persist demo data

    updateLastUpdate();
    populateCidadeFilter();
    applyFilters();
    updateMetrics();
  }

  function saveToStorage() {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(allLeads));
  }

  // ─── DEMO DATA ───────────────────────────────────────────────────
  function getDemoData() {
    const today = todayStr();
    return [
      { id: uid(), empresa: 'TechSol Ltda', contato: 'Ana Lima', telefone: '(71) 99876-5432', cidade: 'Salvador', status: 'Entrada', data: today },
      { id: uid(), empresa: 'Mercado Bom Preço', contato: 'João Silva', telefone: '(71) 98765-4321', cidade: 'Lauro de Freitas', status: 'Aguardo', data: today },
      { id: uid(), empresa: 'Clínica Saúde Plena', contato: 'Dra. Maria', telefone: '(71) 97654-3210', cidade: 'Camaçari', status: 'Dúvida', data: '2025-04-20' },
      { id: uid(), empresa: 'Construtora Norte', contato: 'Carlos Mota', telefone: '(71) 96543-2109', cidade: 'Salvador', status: 'Saída', data: '2025-04-18' },
    ];
  }

  // ─── FILTERS ─────────────────────────────────────────────────────
  function applyFilters() {
    const q       = document.getElementById('searchInput').value.toLowerCase().trim();
    const status  = document.getElementById('filterStatus').value;
    const cidade  = document.getElementById('filterCidade').value;

    filtered = allLeads.filter(l => {
      const matchQ      = !q || l.empresa.toLowerCase().includes(q) || (l.contato||'').toLowerCase().includes(q);
      const matchStatus = !status || l.status === status;
      const matchCidade = !cidade || l.cidade === cidade;
      return matchQ && matchStatus && matchCidade;
    });

    renderTable();
    updateMetrics();
  }

  function populateCidadeFilter() {
    const sel    = document.getElementById('filterCidade');
    const cidades = [...new Set(allLeads.map(l => l.cidade).filter(Boolean))].sort();
    const current = sel.value;
    sel.innerHTML = '<option value="">Todas as cidades</option>';
    cidades.forEach(c => {
      const o = document.createElement('option');
      o.value = c; o.textContent = c;
      if (c === current) o.selected = true;
      sel.appendChild(o);
    });
  }

  // ─── RENDER TABLE ────────────────────────────────────────────────
  function renderTable() {
    const tbody = document.getElementById('leadsTableBody');
    document.getElementById('tableCount').textContent = `${filtered.length} registro${filtered.length !== 1 ? 's' : ''}`;

    if (filtered.length === 0) {
      tbody.innerHTML = `
        <tr>
          <td colspan="6">
            <div class="empty-state">
              <div class="empty-icon">📭</div>
              <strong>Nenhum lead encontrado</strong>
              <p>Tente ajustar os filtros ou cadastre um novo lead.</p>
            </div>
          </td>
        </tr>`;
      return;
    }

    tbody.innerHTML = filtered.map(l => `
      <tr>
        <td class="td-empresa">
          <strong>${esc(l.empresa)}</strong>
          <span>${esc(l.contato || '—')}</span>
        </td>
        <td class="td-phone">${esc(l.telefone || '—')}</td>
        <td>${esc(l.cidade || '—')}</td>
        <td>
          <span class="status-badge ${statusClass(l.status)}">
            <select class="status-select" onchange="changeStatus('${l.id}', this.value)">
              ${['Entrada','Aguardo','Dúvida','Saída'].map(s =>
                `<option value="${s}" ${s === l.status ? 'selected' : ''}>${s}</option>`
              ).join('')}
            </select>
          </span>
        </td>
        <td class="td-date">${formatDate(l.data)}</td>
        <td>
          <div class="td-actions">
            ${l.telefone ? `<button class="btn btn-whatsapp" onclick="openWhatsApp('${l.telefone}')">💬 WA</button>` : ''}
            <button class="btn btn-sage" style="padding:6px 14px;font-size:0.8rem" onclick="editLead('${l.id}')">✏️</button>
            <button class="btn btn-danger" onclick="deleteLead('${l.id}')">🗑️</button>
          </div>
        </td>
      </tr>
    `).join('');
  }

  // ─── METRICS ─────────────────────────────────────────────────────
  function updateMetrics() {
    const today = todayStr();
    document.getElementById('metTotal').textContent   = allLeads.length;
    document.getElementById('metHoje').textContent    = allLeads.filter(l => l.data === today).length;
    document.getElementById('metAguardo').textContent = allLeads.filter(l => l.status === 'Aguardo').length;
    document.getElementById('metSaida').textContent   = allLeads.filter(l => l.status === 'Saída').length;
  }

  // ─── MODAL ───────────────────────────────────────────────────────
  function openModal(id = null) {
    editingId = id;
    const overlay = document.getElementById('modalOverlay');
    document.getElementById('modalTitle').textContent = id ? 'Editar Lead' : 'Novo Lead';

    if (id) {
      const l = allLeads.find(x => x.id === id);
      if (l) {
        document.getElementById('fEmpresa').value  = l.empresa  || '';
        document.getElementById('fContato').value  = l.contato  || '';
        document.getElementById('fTelefone').value = l.telefone || '';
        document.getElementById('fCidade').value   = l.cidade   || '';
        document.getElementById('fStatus').value   = l.status   || 'Entrada';
      }
    } else {
      ['fEmpresa','fContato','fTelefone','fCidade'].forEach(f => document.getElementById(f).value = '');
      document.getElementById('fStatus').value = 'Entrada';
    }

    overlay.classList.add('open');
  }

  function closeModal() {
    document.getElementById('modalOverlay').classList.remove('open');
    editingId = null;
  }

  function handleOverlayClick(e) {
    if (e.target === document.getElementById('modalOverlay')) closeModal();
  }

  function editLead(id) { openModal(id); }

  // ─── SAVE ────────────────────────────────────────────────────────
  function saveLead() {
    const empresa  = document.getElementById('fEmpresa').value.trim();
    const contato  = document.getElementById('fContato').value.trim();
    const telefone = document.getElementById('fTelefone').value.trim();
    const cidade   = document.getElementById('fCidade').value.trim();
    const status   = document.getElementById('fStatus').value;

    if (!empresa) { showToast('Informe o nome da empresa.', 'error'); return; }

    if (editingId) {
      const idx = allLeads.findIndex(l => l.id === editingId);
      if (idx > -1) {
        allLeads[idx] = { ...allLeads[idx], empresa, contato, telefone, cidade, status };
        showToast('Lead atualizado com sucesso!', 'success');
      }
    } else {
      allLeads.unshift({ id: uid(), empresa, contato, telefone, cidade, status, data: todayStr() });
      showToast('Novo lead cadastrado!', 'success');
    }

    saveToStorage();
    closeModal();
    populateCidadeFilter();
    applyFilters();
    updateMetrics();
  }

  // ─── STATUS CHANGE ───────────────────────────────────────────────
  function changeStatus(id, newStatus) {
    const lead = allLeads.find(l => l.id === id);
    if (lead) {
      lead.status = newStatus;
      saveToStorage();
      applyFilters();
      updateMetrics();
      showToast(`Status atualizado para "${newStatus}"`, 'success');
    }
  }

  // ─── DELETE ──────────────────────────────────────────────────────
  function deleteLead(id) {
    if (!confirm('Deseja remover este lead?')) return;
    allLeads = allLeads.filter(l => l.id !== id);
    saveToStorage();
    populateCidadeFilter();
    applyFilters();
    updateMetrics();
    showToast('Lead removido.', 'success');
  }

  // ─── WHATSAPP ────────────────────────────────────────────────────
  function openWhatsApp(phone) {
    const clean = phone.replace(/\D/g, '');
    const num   = clean.startsWith('55') ? clean : '55' + clean;
    window.open(`https://wa.me/${num}`, '_blank');
  }

  // ─── TOAST ───────────────────────────────────────────────────────
  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = `toast ${type} show`;
    clearTimeout(t._timer);
    t._timer = setTimeout(() => t.classList.remove('show'), 3000);
  }

  // ─── HELPERS ─────────────────────────────────────────────────────
  function uid() {
    return Date.now().toString(36) + Math.random().toString(36).slice(2, 7);
  }

  function todayStr() {
    return new Date().toISOString().slice(0, 10);
  }

  function formatDate(str) {
    if (!str) return '—';
    const [y, m, d] = str.split('-');
    return `${d}/${m}/${y}`;
  }

  function esc(str) {
    return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function statusClass(s) {
    const map = { 'Entrada':'status-entrada','Aguardo':'status-aguardo','Dúvida':'status-duvida','Saída':'status-saida' };
    return map[s] || 'status-entrada';
  }

  function updateLastUpdate() {
    const now = new Date();
    document.getElementById('lastUpdate').textContent =
      `Atualizado às ${now.toLocaleTimeString('pt-BR', { hour:'2-digit', minute:'2-digit' })}`;
  }
</script>
</body>
</html>
